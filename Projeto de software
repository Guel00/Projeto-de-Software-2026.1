class Post:
        def __init__(self, autor, conteudo):
            self.author = autor
            self.content = conteudo
            self.likes = 0
            
        def like(self):
                self.likes += 1
            
        def get_info(self):
                return f"{self.author}: {self.content} ({self.likes} likes)"
        def comentario(self, comment):
                return f"{self.author} commented: {comment}"
        def share(self):                
            return f"{self.author} shared a post: {self.content}"
        def save(self):
                return f"{self.author} saved a post: {self.content}"
        def repost(self):
                return f"{self.author} reposted: {self.content}"
        
class chatcomfuncionario:
    def __init__(self, nome_do_funcionario):
        self.nome_do_funcionario = nome_do_funcionario

        self.messages = []
    
    def send_message(self, mensagem):
        self.messages.append((self.nome_do_funcionario, mensagem))
        return f"{self.nome_do_funcionario} sent a message: {mensagem}"
    
    def receive_message(self, mensagem):
        self.messages.append((self.nome_do_funcionario, mensagem))
        return f"{self.nome_do_funcionario} sent a message: {mensagem}"
    
    
    def get_chat_history(self):
        return "\n".join([f"{sender}: {msg}" for sender, msg in self.messages])
    
    
    

    


        

            
            
                