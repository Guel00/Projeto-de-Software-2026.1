class Login:
    def __init__(self):
        self.usuarios = {}
        print("Bem-vindo ao sistema de login!")
    def registrar(self, usuario, senha):
        if usuario in self.usuarios:
            return False
        self.usuarios[usuario] = senha
        return True
    
    def autenticacao(self, usuario, senha):
        if usuario not in self.usuarios:
            return False
        return self.usuarios[usuario] == senha
    
    def alertadesenhaincorreta(self, usuario):
        if usuario not in self.usuarios:
            return "Usuário não encontrado."
        return "Senha incorreta. Tente novamente."
    
    def alterar_senha(self, usuario, anterior_senha, nova_senha):
        if not self.autenticacao(usuario, anterior_senha):
            return False
        self.usuarios[usuario] = nova_senha
        return True
    
